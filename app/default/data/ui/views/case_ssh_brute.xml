<dashboard version="1.1" theme="dark">
  <label>T1110.001 — SSH Brute Force</label>
  <description>Detects SSH password-guessing (hydra, medusa, ncrack) by aggregating Zeek conn.log on TCP/22.</description>

  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="time">
      <label>Time range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="text" token="src_filter" searchWhenChanged="true">
      <label>Source IP</label>
      <default>*</default>
    </input>
  </fieldset>

  <row>
    <panel>
      <title>Suspect groups (60-s windows)</title>
      <single>
        <search>
          <query>`ssh_brute_force`
| where like(src, "$src_filter$") OR "$src_filter$"="*"
| stats count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="colorBy">value</option>
        <option name="rangeValues">[0,1,5]</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <title>Distinct sources</title>
      <single>
        <search>
          <query>`ssh_brute_force`
| where like(src, "$src_filter$") OR "$src_filter$"="*"
| stats dc(src)</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </single>
    </panel>
    <panel>
      <title>Total brute-force attempts</title>
      <single>
        <search>
          <query>`ssh_brute_force`
| where like(src, "$src_filter$") OR "$src_filter$"="*"
| stats sum(connection_count)</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </single>
    </panel>
  </row>

  <row>
    <panel>
      <title>Suspect (src, dest) groups</title>
      <table>
        <search>
          <query>`ssh_brute_force`
| where like(src, "$src_filter$") OR "$src_filter$"="*"
| eval window=strftime(_time, "%Y-%m-%d %H:%M")
| sort -connection_count
| table window, src, dest, connection_count, avg_duration_seconds, sf_fraction, duration_seconds</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="count">25</option>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <title>SSH connection rate, top sources</title>
      <chart>
        <search>
          <query>index=zeek sourcetype=zeek:conn 'id.resp_p'=22
| timechart span=60s count BY src limit=8</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.chart.stackMode">stacked</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>About this detection</title>
      <html>
        <h3>T1110.001 — SSH Brute Force</h3>
        <p>
          hydra, medusa, ncrack, and similar tools throw credential
          wordlists at exposed SSH endpoints. Each attempt is a
          complete TCP handshake (Zeek records <code>SF</code>) that
          closes within a few seconds when auth fails.
        </p>
        <p>
          The detection requires <em>both</em> high connection count
          (≥ 20) and short average duration (≤ 5 s) per (src, dest) over
          a 60-s window. Long SSH sessions and one-off auth probes don't
          fire.
        </p>
        <p>
          Tuning + false-positive notes:
          <a href="https://github.com/JacobRHess/detlab/blob/main/cases/t1110_001_ssh_brute_force/README.md" target="_blank">cases/t1110_001_ssh_brute_force/README.md</a>
        </p>
      </html>
    </panel>
  </row>
</dashboard>
