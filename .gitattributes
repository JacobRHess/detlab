# GitHub Linguist overrides — make the language stats reflect what this
# repo actually is (a Splunk-focused detection lab) instead of what the
# default classifier sees (a React/TypeScript site with some Python
# alongside, because Linguist excludes YAML/JSON/conf/SPL by default).
#
# `linguist-detectable=true` forces a normally-data file to count.
# `linguist-language=X` aliases an unrecognised extension to a known one.
# `linguist-generated` excludes it from stats AND collapses it in PR diffs.

# --- Splunk content: count it as code ---

# SPL (search.spl) — closest recognised language is SQL (similar pipe shape).
*.spl                              linguist-detectable=true linguist-language=SQL

# Splunk .conf files (macros, savedsearches, props, correlationsearches,
# eventtypes, tags, workflow_actions, analyticstories) — INI-shaped.
*.conf                             linguist-detectable=true linguist-language=INI

# Sigma rules — author-written YAML, treat as code rather than data.
**/sigma.yml                       linguist-detectable=true linguist-language=YAML

# Splunk SimpleXML dashboards — the per-case + overview/coverage views.
app/default/data/ui/**/*.xml       linguist-detectable=true linguist-language=XML

# --- Generated / vendored artifacts: hide from stats ---

# Web-data outputs of scripts/build_web_data.py
web/src/data/cases.json            linguist-generated
web/public/cases/*.json            linguist-generated
web/public/py/*.py                 linguist-generated

# Splunk-app conf files generated by scripts/build_app.py — listed
# explicitly because the *.conf rule above would otherwise count them.
app/default/macros.conf            linguist-generated
app/default/savedsearches.conf     linguist-generated
app/default/correlationsearches.conf linguist-generated
app/default/analyticstories.conf   linguist-generated
app/default/eventtypes.conf        linguist-generated
app/default/tags.conf              linguist-generated
app/default/workflow_actions.conf  linguist-generated
app/lookups/detlab_cases.csv       linguist-generated

# npm lockfile — committed for reproducible installs but not author code
web/package-lock.json              linguist-generated

# Synthetic Zeek / Suricata fixtures — JSON-lines test data, not source code
**/tests/positive_*.log            linguist-generated linguist-language=JSON
**/tests/negative_*.log            linguist-generated linguist-language=JSON

# Vite + tsc build output (kept gitignored too, listed for safety)
web/dist/                          linguist-generated
build/                             linguist-generated
